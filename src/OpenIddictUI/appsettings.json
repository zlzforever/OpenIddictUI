{
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "User ID=${SOCODB_DB_USER};Password=${SOCODB_DB_PASSWORD};Host=10.0.10.190;Port=5432;Database=socodb_dev;Pooling=true;"
  },
  "OpenIddictUI": {
    "Issuer": "",
    "VerifyCodeLength": 4,
    "SmsSender": "Console",
    "ForcePasswordSecurityPolicy": false,
    "MigrationsHistoryTable": "openiddict_migrations_history",
    "ForceEncryptPaths": ["/reset-password-by-sms", "/change-password"]
  },
  "AliYun": {
    "AccessKey": "",
    "Secret": "",
    "Endpoint": "dysmsapi.aliyuncs.com",
    "SMS": {
      "SignName": "",
      "Templates": {
        "+86": "",
        "other": ""
      }
    }
  },
  "PostgresCache": {
    "SchemaName": "public",
    "TableName": "openiddict_cache_entries",
    "CreateIfNotExists": true,
    "UseWAL": false,
    "ExpiredItemsDeletionInterval": "00:30:00",
    "DefaultSlidingExpiration": "00:20:00"
  },
  "Identity": {
    "ClaimsIdentity": {
      "EmailClaimType": "email",
      "SecurityStampClaimType": "security-stamp"
    },
    "Password": {
      "RequireDigit": true,
      "RequireLowercase": true,
      "RequiredLength": 8,
      "RequireNonAlphanumeric": true,
      "RequireUppercase": true,
      "RequiredUniqueChars": 1
    },
    "SignIn": {
      "RequireConfirmedEmail": false,
      "RequireConfirmedAccount": false,
      "RequireConfirmedPhoneNumber": false
    },
    "Lockout": {
      "DefaultLockoutTimeSpan": "00:03:00",
      "MaxFailedAccessAttempts": 5,
      "AllowedForNewUsers": true
    },
    "User": {
      "AllowedUserNameCharacters": "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789-._@+",
      "RequireUniqueEmail": false
    }
  },
  "IdentityExtension": {
    "SoftDeleteColumn": "is_deleted",
    "Tables": {
      "Users": "wild_goose_user",
      "Roles": "wild_goose_role",
      "UserRoles": "wild_goose_user_role",
      "UserClaims": "wild_goose_user_claim",
      "UserLogins": "wild_goose_user_login",
      "RoleClaims": "wild_goose_role_claim",
      "UserTokens": "wild_goose_user_token"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {SourceContext} {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/log-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 14,
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {SourceContext} {Message:lj}{NewLine}{Exception}"
        }
      }
    ]
  },
  "CookiePolicy": {
    "MinimumSameSitePolicy": "Lax",
    "Secure": "None"
  },
  "ApplicationCookieAuthentication": {
    "LoginPath": "/account/login",
    "ReturnUrlParameter": "returnUrl",
    "LogoutPath": "/account/logout",
    "AccessDeniedPath": "/account/login",
    "ExpireTimeSpan": "120:00:00",
    "SlidingExpiration": true,
    "Cookie": {
      "Name": "idsrv",
      "HttpOnly": true,
      "SameSite": "Lax"
    }
  },
  "ExternalCookieAuthentication": {
    "Cookie": {
      "Name": "idsrv.external",
      "HttpOnly": true,
      "SameSite": "Lax"
    }
  },
  "TwoFactorUserIdCookieAuthentication": {
    "Cookie": {
      "Name": "idsrv.twoFactorUserId",
      "HttpOnly": true,
      "SameSite": "Lax"
    }
  }
}
